    <Folder>
      <name>Park Shuttles</name>
      <Placemark>
        <name>Muir Woods Shuttle
</name>
        <description>Shuttles run seasonally (approximately April to September) from Larkspur and Sausalito ferry landings.&lt;br&gt;&lt;br&gt;https://gomuirwoods.com/muir/shuttleInfo</description>
        <styleUrl>#icon-1502-000000-labelson</styleUrl>
        <Point>
          <coordinates>
            -122.5724979,37.8928503,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Emerald Bay State Park</name>
        <description>SEASONAL SERVICE - SUMMER ONLY&lt;br&gt;&lt;br&gt;https://www.keeptahoeblue.org/emerald-bay-shuttle/</description>
